# API

# Public base URL of the service (used in confirmation links sent via email)
APP_BASE_URL=http://localhost:8080
# HTTP scheme used by the server (http or https)
SCHEME=http

# Database

# PostgreSQL connection string (required)
DATABASE_URL=postgres://app:app@localhost:5432/app?sslmode=disable
# Path to migration files (file:// prefix for local directory)
MIGRATIONS_PATH=file://migrations
# Timeout for the initial database ping on startup
DATABASE_PING_TIMEOUT=5s

# GitHub API

# Personal access token for the GitHub API (increases rate limit from 60 to 5000 req/h)
GITHUB_AUTH_TOKEN=
# GitHub API base URL (override for GitHub Enterprise)
GITHUB_API_BASE_URL=https://api.github.com
# Timeout for individual GitHub API requests
GITHUB_API_TIMEOUT=5s

# SMTP

# SMTP server hostname
SMTP_HOST=localhost
# SMTP server port (1025 = MailHog dev default; 587 = STARTTLS; 465 = TLS)
SMTP_PORT=1025
# Sender address shown in notification emails
SMTP_FROM=no-reply@github-release-notification.local
# SMTP credentials (leave empty if the server does not require auth)
SMTP_USERNAME=
SMTP_PASSWORD=

# Scanner

# How often the scanner polls GitHub for new releases
SCANNER_INTERVAL=1m

# Notifier

# How often the notifier sends pending email notifications
NOTIFIER_INTERVAL=1m
